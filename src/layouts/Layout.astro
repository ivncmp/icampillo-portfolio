---
import '../styles/globals.css';
import BootLoader from '../components/BootLoader.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/brand/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/brand/favicon.svg" />
    <link rel="shortcut icon" href="/brand/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/brand/apple-touch-icon.png" />
    <link rel="manifest" href="/brand/site.webmanifest" />
    <meta name="theme-color" content="#c4fa03" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Iván Campillo — Cloud Architect & Head of Technology with 20+ years of experience driving innovation. Scalable cloud solutions, Web3, blockchain, and SaaS platforms." />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Cloud Architect & Head of Technology with 20+ years driving innovation in Spain, UK and the UAE." />
    <meta property="og:image" content="https://icampillo.com/og-image.png" />
    <meta property="og:url" content="https://icampillo.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Cloud Architect & Head of Technology with 20+ years driving innovation in Spain, UK and the UAE." />
    <meta name="twitter:image" content="https://icampillo.com/og-image.png" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('lang');
        var lang = stored || (navigator.language.startsWith('es') ? 'es' : 'en');
        document.documentElement.lang = lang;
      })();
    </script>
    <style>
      body { visibility: hidden; }
      body.ready { visibility: visible; }
    </style>
  </head>
  <body class="scanlines grain">
    <BootLoader />
    <slot />
    <script is:inline>document.body.classList.add('ready');</script>
    <script is:inline>
      (function() {
        var btn = document.getElementById('lang-toggle');
        if (btn) {
          btn.addEventListener('click', function() {
            var next = document.documentElement.lang === 'es' ? 'en' : 'es';
            document.documentElement.lang = next;
            localStorage.setItem('lang', next);
          });
        }
      })();
    </script>
    <script is:inline>
      (function() {
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('[data-reveal],[data-stagger]').forEach(function(el) {
          obs.observe(el);
        });
      })();
    </script>
  </body>
</html>
