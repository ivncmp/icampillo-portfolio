---
const experiences = [
	{
		company: 'Fundador y CTO',
		role: 'Valora Studio',
		period: '2025 - present',
		description: 'Socio y responsable tecnológico de Valora Studio, liderando la arquitectura IT de todos los proyectos, incluida la plataforma Web3 5TARS.io. En este rol diseño infraestructuras escalables en la nube, dirijo equipos de desarrollo y tomo decisiones estratégicas sobre el stack tecnológico.'
	},
	{
		company: 'Instructor',
		role: 'Keep Coding',
		period: '2023 - present',
		description: 'Formador en bootcamp de desarrollo blockchain. Enseño a construir y desplegar smart contracts usando Solidity y Web3.js.'
	},
	{
		company: 'Head of Technology',
		role: 'The Key Talent',
		period: '2017 - 2022',
		description: 'Director técnico y líder de producto en la software factory de The Key Talent. Encargado del stack tecnológico, la calidad del código y la coordinación de los equipos de desarrollo.'
	},
	{
		company: 'Lead Software Architect',
		role: 'BBVA Next',
		period: '2014 - 2017',
		description: 'Arquitecto senior de software, responsable de arquitectura tanto en frontend como backend, aplicando patrones de diseño y buenas prácticas.'
	},
	{
		company: 'Software Engineer Team Lead',
		role: 'Oracle Cerner (UK)',
		period: '2012 - 2014',
		description: 'Líder técnico en el sector salud para el NHS británico. Responsable de desarrollo con Java y Eclipse RCP y coordinación de equipo en entorno internacional.'
	}
];
---

<section id="experience">
	<div class="container">
		<h2 class="section-title">Puntos clave en mi trayectoria profesional</h2>
		
		<div class="timeline">
			{experiences.map((exp, index) => (
				<div class="timeline-item" style={`animation-delay: ${index * 0.1}s`}>
					<div class="timeline-marker">
						<div class="marker-dot"></div>
						<div class="marker-line"></div>
					</div>
					
					<div class="timeline-content card">
						<div class="timeline-header">
							<div>
								<h3 class="exp-company">{exp.company}</h3>
								<h4 class="exp-role">{exp.role}</h4>
							</div>
							<span class="exp-period">{exp.period}</span>
						</div>
						<p class="exp-description">{exp.description}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	#experience {
		background: var(--bg-dark);
	}

	.section-title {
		text-align: center;
		margin-bottom: 4rem;
		font-size: 2.5rem;
		color: var(--text-primary);
	}

	.timeline {
		max-width: 900px;
		margin: 0 auto;
		position: relative;
	}

	.timeline-item {
		display: grid;
		grid-template-columns: 80px 1fr;
		gap: 2rem;
		margin-bottom: 3rem;
		opacity: 0;
		animation: slideInLeft 0.6s forwards;
	}

	.timeline-marker {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.marker-dot {
		width: 16px;
		height: 16px;
		background: var(--accent-purple);
		border-radius: 50%;
		box-shadow: 0 0 20px rgba(168, 85, 247, 0.5);
		z-index: 1;
		flex-shrink: 0;
	}

	.marker-line {
		width: 2px;
		flex: 1;
		background: linear-gradient(to bottom, var(--accent-purple), transparent);
		margin-top: 0.5rem;
	}

	.timeline-item:last-child .marker-line {
		display: none;
	}

	.timeline-content {
		min-height: 150px;
	}

	.timeline-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1rem;
		gap: 1rem;
	}

	.exp-company {
		font-size: 1.4rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 0.25rem;
	}

	.exp-role {
		font-size: 1.1rem;
		font-weight: 500;
		color: var(--accent-purple);
	}

	.exp-period {
		padding: 0.5rem 1rem;
		background: var(--bg-dark);
		border: 1px solid var(--border-color);
		border-radius: 2rem;
		font-size: 0.9rem;
		color: var(--text-secondary);
		white-space: nowrap;
	}

	.exp-description {
		color: var(--text-secondary);
		line-height: 1.7;
	}

	@keyframes slideInLeft {
		from {
			opacity: 0;
			transform: translateX(-50px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	@media (max-width: 768px) {
		.timeline-item {
			grid-template-columns: 50px 1fr;
			gap: 1rem;
		}

		.section-title {
			font-size: 1.75rem;
		}

		.exp-company {
			font-size: 1.2rem;
		}

		.timeline-header {
			flex-direction: column;
		}

		.exp-period {
			align-self: flex-start;
		}
	}
</style>
