---
import { EXPERIENCE } from '../data/index';
import SectionHead from './SectionHead.astro';
import I18n from './I18n.astro';

const typeColors: Record<string, { bg: string; fg: string; border: string }> = {
  founder:  { bg: 'rgba(200,255,0,0.1)',  fg: 'var(--accent)',  border: 'rgba(200,255,0,0.4)' },
  lead:     { bg: 'rgba(210,168,255,0.1)', fg: 'var(--purple)', border: 'rgba(210,168,255,0.4)' },
  ic:       { bg: 'rgba(121,192,255,0.1)', fg: 'var(--cyan)',   border: 'rgba(121,192,255,0.4)' },
  teaching: { bg: 'rgba(255,166,87,0.1)',  fg: 'var(--warn)',   border: 'rgba(255,166,87,0.4)' },
};

const typeLabel: Record<string, string> = {
  founder: 'FOUNDER',
  lead: 'LEAD',
  ic: 'IC',
  teaching: 'TEACHING',
};

const COMPANY_LOGOS: Record<string, string> = {};
---

<section id="career" class="experience-section">
  <div class="experience-inner">
    <SectionHead
      cmd="git log --author=ivan --oneline"
      title='Mi <span class="accent">trayectoria</span>.'
      titleEn='This is my <span class="accent">career</span>.'
      kicker="Veinte años de software — de satélites ESA a Web3. Ingeniero, arquitecto, CTO y founder."
      kickerEn="Twenty years of software — from ESA satellites to Web3. Engineer, architect, CTO, and founder."
    />

    <div class="experience-timeline" data-stagger>
      {EXPERIENCE.map((exp, i) => {
        const c = typeColors[exp.type];
        const isLast = i === EXPERIENCE.length - 1;
        const [startYear, endYear] = exp.years.split(' — ');
        return (
          <div class="exp-row">
            <!-- Years -->
            <div class="exp-years">
              <div class="exp-year-start">{startYear}</div>
              <div class="exp-year-end">→ {endYear}</div>
              <div class="exp-year-index">{String(i + 1).padStart(2, '0')} / {String(EXPERIENCE.length).padStart(2, '0')}</div>
            </div>

            <!-- Timeline rail -->
            <div class="exp-rail">
              {!isLast && <div class="exp-rail-line" />}
              <div
                class="exp-rail-dot"
                style={`background: ${c.fg}; box-shadow: 0 0 0 5px var(--bg-soft), 0 0 0 6px ${c.border}, 0 0 18px ${c.border}`}
              />
            </div>

            <!-- Card -->
            <div class="exp-card">
              <div class="exp-card-logo">
                {COMPANY_LOGOS[exp.company] ? (
                  <img src={COMPANY_LOGOS[exp.company]} alt={exp.company} width="40" height="40" loading="lazy" />
                ) : (
                  <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="10" width="5" height="22" rx="1.5" fill="currentColor" opacity="0.25"/>
                    <rect x="10" y="16" width="5" height="16" rx="1.5" fill="currentColor" opacity="0.35"/>
                    <rect x="18" y="6" width="5" height="28" rx="1.5" fill="currentColor" opacity="0.45"/>
                    <rect x="26" y="10" width="12" height="20" rx="2.5" stroke="currentColor" stroke-width="2" opacity="0.5"/>
                  </svg>
                )}
              </div>
              <div class="exp-card-main">
                <div class="exp-card-top">
                  <span
                    class="exp-type-badge"
                    style={`background: ${c.bg}; color: ${c.fg}; border-color: ${c.border}`}
                  >
                    {typeLabel[exp.type]}
                  </span>
                  <span class="exp-card-period">· {exp.years}</span>
                </div>
                <h3 class="exp-role">{exp.role}</h3>
                <div class="exp-company">@ {exp.company}</div>
                <p class="exp-desc"><I18n es={exp.desc} en={exp.descEn} /></p>
              </div>

              <div class="exp-card-sidebar">
                <div>
                  <div class="exp-sidebar-label">▸ focus</div>
                  <div class="exp-sidebar-tags">
                    {exp.tags.map((t) => (
                      <span class="exp-tag">{t}</span>
                    ))}
                  </div>
                </div>
                <div class="exp-sidebar-type">
                  <div class="exp-sidebar-label">▸ type</div>
                  <div class="exp-sidebar-type-val" style={`color: ${c.fg}`}>
                    {exp.type}()
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .experience-section {
    padding: 120px 32px;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .experience-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .exp-row {
    display: grid;
    grid-template-columns: 160px 40px 1fr;
    gap: 28px;
    padding-bottom: 36px;
    position: relative;
  }

  .exp-row:last-child { padding-bottom: 0; }

  .exp-years {
    padding-top: 6px;
    text-align: right;
  }

  .exp-year-start {
    font-family: var(--display);
    font-size: 28px;
    font-weight: 700;
    color: var(--fg);
    line-height: 1;
    letter-spacing: -1px;
  }

  .exp-year-end {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg-mute);
    margin-top: 4px;
  }

  .exp-year-index {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--fg-mute);
    margin-top: 12px;
  }

  .exp-rail {
    position: relative;
  }

  .exp-rail-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: -36px;
    width: 1px;
    background: var(--border-2);
    transform: translateX(-0.5px);
  }

  .exp-row:last-child .exp-rail-line {
    display: none;
  }

  .exp-rail-dot {
    position: relative;
    z-index: 1;
    width: 14px;
    height: 14px;
    border-radius: 999px;
    margin: 10px auto 0;
  }

  .exp-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 10px;
    display: grid;
    grid-template-columns: 72px 1fr 260px;
    overflow: hidden;
  }

  .exp-card-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.15);
    padding: 16px;
    color: var(--fg-dim);
  }

  .exp-card-logo svg {
    width: 40px;
    height: 40px;
  }

  .exp-card-logo img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    border-radius: 6px;
  }

  .exp-card-main { padding: 24px; }

  .exp-card-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .exp-type-badge {
    font-family: var(--mono);
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 3px;
    border: 1px solid;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .exp-card-period {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg-mute);
  }

  .exp-role {
    font-family: var(--display);
    font-size: 28px;
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.6px;
    line-height: 1.1;
  }

  .exp-company {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--accent);
    margin-top: 6px;
  }

  .exp-desc {
    font-family: var(--sans);
    font-size: 15px;
    color: var(--fg-dim);
    line-height: 1.6;
    margin-top: 16px;
    max-width: 560px;
  }

  .exp-card-sidebar {
    padding: 24px;
    border-left: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .exp-sidebar-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--fg-mute);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .exp-sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .exp-tag {
    font-family: var(--mono);
    font-size: 11px;
    padding: 3px 8px;
    border: 1px solid var(--border-2);
    color: var(--fg-dim);
    border-radius: 3px;
    white-space: nowrap;
  }

  .exp-sidebar-type { margin-top: auto; }

  .exp-sidebar-type-val {
    font-family: var(--mono);
    font-size: 12px;
  }

  @media (max-width: 900px) {
    .exp-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .exp-years { text-align: left; display: flex; gap: 12px; align-items: baseline; }
    .exp-year-index { margin-top: 0; }
    .exp-rail { display: none; }

    .exp-card {
      grid-template-columns: 56px 1fr;
    }

    .exp-card-sidebar {
      grid-column: 1 / -1;
      border-left: none;
      border-top: 1px solid var(--border);
    }
  }
</style>
