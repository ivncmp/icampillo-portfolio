---
const items = [
  { label: 'whoami', href: '#top', id: 'top' },
  { label: 'services', href: '#services', id: 'services' },
  { label: 'work', href: '#work', id: 'work' },
  { label: 'stack', href: '#stack', id: 'stack' },
  { label: 'career', href: '#career', id: 'career' },
  { label: 'oss', href: '#oss', id: 'oss' },
];
---

<nav id="main-nav" class="nav">
  <div class="nav-inner">
    <a href="#top" class="nav-logo">
      <span class="nav-logo-badge">ic</span>
      <span class="nav-logo-name">icampillo</span>
      <span class="nav-logo-tld">.com</span>
    </a>

    <div class="nav-links">
      {items.map((item) => (
        <a href={item.href} class="nav-link" data-section={item.id}>
          <span class="nav-link-prefix">./</span>{item.label}
          <span class="nav-link-underline" />
        </a>
      ))}
    </div>

    <div class="nav-right">
      <span class="nav-available">
        <span class="nav-available-dot" />
        available
      </span>
      <button id="lang-toggle" class="nav-lang-toggle" aria-label="Toggle language">
        <span data-lang="es">EN</span>
        <span data-lang="en">ES</span>
      </button>
      <a href="#contact" class="btn btn-primary nav-cta">
        <span>▸</span> let's talk
      </a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 14px 32px;
    border-bottom: 1px solid transparent;
    transition: all 180ms ease;
  }

  .nav.scrolled {
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom-color: var(--border);
  }

  .nav-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 16px;
    font-weight: 600;
  }

  .nav-logo-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--accent);
    color: #000;
    font-family: var(--mono);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: -0.5px;
  }

  .nav-logo-name {
    color: var(--fg);
  }

  .nav-logo-tld {
    color: var(--fg-mute);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nav-link {
    position: relative;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-dim);
    padding: 8px 12px;
    border-radius: 4px;
    transition: color 180ms ease, background 180ms ease;
  }

  .nav-link:hover {
    color: var(--fg);
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-link-prefix {
    color: var(--fg-mute);
  }

  .nav-link.active {
    color: var(--fg);
  }

  .nav-link.active .nav-link-prefix {
    color: var(--accent);
  }

  .nav-link-underline {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 4px;
    height: 1.5px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 280ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .nav-link.active .nav-link-underline {
    transform: scaleX(1);
    box-shadow: 0 0 6px rgba(200, 255, 0, 0.5);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-available {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg-dim);
    padding: 7px 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .nav-available-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--accent-2);
    box-shadow: 0 0 6px var(--accent-2);
    animation: pulse 1.8s ease-in-out infinite;
  }

  .nav-lang-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--fg-dim);
    padding: 7px 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    transition: all 180ms ease;
    letter-spacing: 1px;
    min-width: 38px;
  }

  .nav-lang-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(200, 255, 0, 0.06);
  }

  .nav-cta {
    font-size: 12px;
    padding: 8px 14px;
  }

  @media (max-width: 900px) {
    .nav-links,
    .nav-available {
      display: none;
    }
  }
</style>

<script>
  const nav = document.getElementById('main-nav')!;

  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  const links = nav.querySelectorAll<HTMLAnchorElement>('.nav-link');
  const sectionIds = Array.from(links).map((l) => l.dataset.section!);
  const visible = new Map<string, number>();

  sectionIds.forEach((id) => {
    const el = document.getElementById(id);
    if (!el) return;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            visible.set(id, e.intersectionRatio);
          } else {
            visible.delete(id);
          }
          if (visible.size > 0) {
            const [topId] = [...visible.entries()].sort((a, b) => b[1] - a[1])[0];
            links.forEach((l) => {
              l.classList.toggle('active', l.dataset.section === topId);
            });
          }
        });
      },
      { threshold: [0.1, 0.3, 0.5, 0.7], rootMargin: '-120px 0px -40% 0px' },
    );
    io.observe(el);
  });
</script>
