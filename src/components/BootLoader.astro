---

<div id="boot-loader" class="boot-overlay">
  <div class="boot-container">
    <div class="boot-logo">
      <span class="boot-logo-badge">ic</span>
      <span class="boot-logo-name">icampillo</span>
      <span class="boot-logo-tld">.com</span>
    </div>
    <div class="boot-window">
      <div class="boot-titlebar">
        <div class="boot-dots">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
        </div>
        <span class="boot-title">icampillo.com</span>
      </div>
    <div class="boot-body">
      <pre id="boot-log" class="boot-log"></pre>
      <span id="boot-cursor" class="boot-cursor">▌</span>
    </div>
  </div>
  </div>
</div>

<style>
  .boot-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background-color: var(--bg-soft);
    background-image:
      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(200, 255, 0, 0.06), transparent 60%);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }

  .boot-overlay.done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .boot-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .boot-logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .boot-logo-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--accent);
    color: #000;
    font-family: var(--mono);
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .boot-logo-name {
    font-family: var(--mono);
    font-size: 18px;
    font-weight: 600;
    color: var(--fg);
  }

  .boot-logo-tld {
    font-family: var(--mono);
    font-size: 18px;
    font-weight: 600;
    color: var(--fg-mute);
  }

  .boot-window {
    width: 600px;
    max-width: calc(100vw - 40px);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border-2);
    box-shadow:
      0 0 80px rgba(200, 255, 0, 0.04),
      0 20px 60px rgba(0, 0, 0, 0.6);
  }

  .boot-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: #1a1a1a;
    border-bottom: 1px solid var(--border);
  }

  .boot-title {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--fg-dim);
    font-weight: 500;
  }

  .boot-dots {
    display: flex;
    gap: 8px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }

  .boot-body {
    background: #0d0d0d;
    padding: 24px 20px;
    min-height: 200px;
    max-height: 360px;
    overflow-y: auto;
    scrollbar-width: none;
  }

  .boot-body::-webkit-scrollbar {
    display: none;
  }

  .boot-log {
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.8;
    color: var(--accent);
    white-space: pre-wrap;
    word-break: break-all;
    margin: 0;
  }

  .boot-cursor {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--accent);
    animation: terminal-blink 0.7s step-end infinite;
  }

  @media (max-width: 480px) {
    .boot-window {
      border-radius: 8px;
    }

    .boot-log {
      font-size: 11px;
    }

    .boot-body {
      padding: 16px 14px;
      min-height: 160px;
    }
  }
</style>

<script is:inline>
(function () {
  var lines = [
    { text: '[BIOS] icampillo.com v4.0.0', delay: 60 },
    { text: '[BOOT] Loading kernel astro@6.x... OK', delay: 80 },
    { text: '[INIT] Mounting /dev/portfolio... OK', delay: 60 },
    { text: '[SYS]  20+ years of experience detected', delay: 50 },
    { text: '[NET]  Madrid, ES (CET)... connected', delay: 70 },
    { text: '[PKG]  TypeScript, Python, Solidity, Rust, Go', delay: 60 },
    { text: '[PKG]  AWS, Terraform, K8s, Docker... loaded', delay: 60 },
    { text: '[SVC]  cloud-architect.service ........ OK', delay: 50 },
    { text: '[SVC]  ai-engineer.service ............ OK', delay: 45 },
    { text: '[SVC]  blockchain-dev.service ......... OK', delay: 45 },
    { text: '[SVC]  full-stack.service ............. OK', delay: 45 },
    { text: '[SVC]  tech-lead.service .............. OK', delay: 45 },
    { text: '[GPU]  Scanlines + grain... active', delay: 50 },
    { text: '[TTY]  Figtree · Space Grotesk · JetBrains Mono', delay: 50 },
    { text: '', delay: 30 },
    { text: '[OK]   All systems operational.', delay: 120 },
    { text: 'Welcome, visitor_', delay: 150 },
  ];

  var logEl = document.getElementById('boot-log');
  var cursorEl = document.getElementById('boot-cursor');
  var overlay = document.getElementById('boot-loader');
  var bodyEl = document.querySelector('.boot-body');
  var i = 0;

  function nextLine() {
    if (i >= lines.length) {
      cursorEl.style.display = 'none';
      setTimeout(function () {
        overlay.classList.add('done');
        setTimeout(function () { overlay.remove(); }, 500);
      }, 250);
      return;
    }

    var line = lines[i];
    logEl.textContent += line.text + '\n';
    bodyEl.scrollTop = bodyEl.scrollHeight;
    i++;
    setTimeout(nextLine, line.delay);
  }

  setTimeout(nextLine, 200);
})();
</script>
