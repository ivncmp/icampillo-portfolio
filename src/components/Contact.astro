---
import { CONTACT } from '../data/index';

const channels = CONTACT.channels;
---

<section id="contact" class="contact-section">
  <div class="contact-inner">
    <div class="contact-grid">
      <!-- Left: CTA + channels -->
      <div data-reveal="left">
        <div class="contact-cmd">
          <span class="contact-cmd-dollar">$</span> ./contact.sh
        </div>

        <h2 class="contact-title">
          <span data-lang="es">¿<span class="contact-title-accent">Hablamos</span>?</span>
          <span data-lang="en">Do you want to <span class="contact-title-accent">talk</span>?</span>
        </h2>

        <p class="contact-subtitle">
          <span data-lang="es">Consultoría selectiva, fractional CTO y arquitectura para proyectos serios. Respuesta en menos de 24h.</span>
          <span data-lang="en">Selective consulting, fractional CTO, and architecture for serious projects. Response in under 24h.</span>
        </p>

        <div class="contact-channels">
          {channels.map((c) => (
            <a href={c.url} class="contact-channel">
              <span class="contact-channel-icon">{c.icon}</span>
              <span class="contact-channel-label">{c.label}</span>
              <span class="contact-channel-value">{c.value}</span>
              <span class="contact-channel-arrow">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact-form-window" data-reveal="right">
        <div class="contact-form-chrome">
          <span class="contact-form-dot" style="background: #ff5f56" />
          <span class="contact-form-dot" style="background: #ffbd2e" />
          <span class="contact-form-dot" style="background: #27c93f" />
          <div class="contact-form-chrome-title">new-message.sh</div>
        </div>

        <div class="contact-form-body">
          <div class="contact-form-init">
            <div><span class="contact-form-init-dollar">$</span> <span class="contact-form-init-cmd">./contact --new</span></div>
            <div class="contact-form-init-mute">initializing form...</div>
            <div class="contact-form-init-ok">✓ ready · please fill in below</div>
          </div>

          <div class="contact-field">
            <div class="contact-field-label">
              <span class="contact-field-prompt">&gt;</span> name:
            </div>
            <input type="text" placeholder="Jane Doe" class="contact-input" />
          </div>

          <div class="contact-field">
            <div class="contact-field-label">
              <span class="contact-field-prompt">&gt;</span> email:
            </div>
            <input type="email" placeholder="jane@company.com" class="contact-input" />
          </div>

          <div class="contact-field">
            <div class="contact-field-label">
              <span class="contact-field-prompt">&gt;</span> message:
            </div>
            <textarea data-lang="es" placeholder="Quiero llevar X de 0 a 100..." rows={5} class="contact-input contact-textarea" />
            <textarea data-lang="en" placeholder="I want to take X from 0 to 100..." rows={5} class="contact-input contact-textarea" />
          </div>

          <button class="contact-submit">▸ ./send-message</button>

          <div class="contact-tip">
            tip: press <span class="contact-tip-key">⌘+↵</span> to send
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--bg-soft);
    padding: 140px 32px 120px;
    position: relative;
    overflow: hidden;
  }

  .contact-section::before {
    content: '';
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(200,255,0,0.06), transparent 65%);
    pointer-events: none;
    animation: glow-pulse 10s ease-in-out infinite;
  }

  .contact-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 80px;
    align-items: flex-start;
  }

  .contact-cmd {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 10px;
    border: 1px solid rgba(200, 255, 0, 0.3);
    border-radius: 4px;
    background: rgba(200, 255, 0, 0.05);
    margin-bottom: 24px;
  }

  .contact-cmd-dollar { color: var(--fg-dim); }

  .contact-title {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 0.95;
    letter-spacing: 0;
    color: var(--fg);
    text-wrap: balance;
  }

  .contact-title-accent { color: var(--accent); }

  .contact-subtitle {
    font-family: var(--sans);
    font-size: 19px;
    color: var(--fg-dim);
    line-height: 1.5;
    margin-top: 24px;
    max-width: 520px;
  }

  .contact-channels {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    max-width: 440px;
  }

  .contact-channel {
    background: var(--bg-elev);
    padding: 14px 18px;
    display: grid;
    grid-template-columns: 24px 80px 1fr 20px;
    gap: 14px;
    align-items: center;
    font-family: var(--mono);
    font-size: 13px;
    transition: background 120ms ease;
  }

  .contact-channel:hover { background: var(--bg-panel-2); }
  .contact-channel-icon { color: var(--accent); }
  .contact-channel-label { color: var(--fg-mute); }
  .contact-channel-value { color: var(--fg); }
  .contact-channel-arrow { color: var(--fg-mute); }

  /* ── Form window ── */
  .contact-form-window {
    background: var(--bg-panel);
    border: 1px solid var(--border-2);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .contact-form-chrome {
    background: var(--bg-panel-2);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border-2);
  }

  .contact-form-dot {
    width: 12px;
    height: 12px;
    border-radius: 999px;
  }

  .contact-form-chrome-title {
    flex: 1;
    text-align: center;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg-dim);
  }

  .contact-form-body { padding: 24px; }

  .contact-form-init {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-mute);
    margin-bottom: 20px;
    line-height: 1.7;
  }

  .contact-form-init-dollar { color: var(--accent-2); }
  .contact-form-init-cmd { color: var(--fg); }
  .contact-form-init-mute { color: var(--fg-mute); }
  .contact-form-init-ok { color: var(--accent-2); }

  .contact-field { margin-bottom: 14px; }

  .contact-field-label {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg-dim);
    margin-bottom: 6px;
  }

  .contact-field-prompt { color: var(--accent); }

  .contact-input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--border-2);
    border-radius: 4px;
    padding: 10px 12px;
    font-family: var(--mono);
    font-size: 14px;
    color: var(--fg);
    outline: none;
    transition: border-color 120ms ease;
  }

  .contact-input:focus { border-color: var(--accent); }
  .contact-input::placeholder { color: var(--fg-mute); }

  .contact-textarea { resize: vertical; }

  .contact-submit {
    width: 100%;
    margin-top: 10px;
    background: var(--accent);
    color: #000;
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 700;
    border: none;
    padding: 14px;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: transform 120ms ease;
  }

  .contact-submit:hover { transform: translateY(-1px); }

  .contact-tip {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--fg-mute);
    margin-top: 12px;
    text-align: center;
  }

  .contact-tip-key { color: var(--accent); }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  @media (max-width: 600px) {
    .contact-section { padding: 80px 20px; }
  }
</style>
