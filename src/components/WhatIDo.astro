---
const services = [
	{
		icon: 'fas fa-cloud',
		iconColor: '#a855f7',
		title: 'Arquitectura e infraestructura en la nube'
	},
	{
		icon: 'fas fa-link',
		iconColor: '#3b82f6',
		title: 'Blockchain & Smart Contracts'
	},
	{
		icon: 'fas fa-code',
		iconColor: '#10b981',
		title: 'Full Stack Development'
	},
	{
		icon: 'fas fa-plug',
		iconColor: '#a855f7',
		title: 'Diseño API & Integración'
	},
	{
		icon: 'fas fa-users',
		iconColor: '#3b82f6',
		title: 'Liderazgo de equipos tecnológicos'
	},
	{
		icon: 'fas fa-graduation-cap',
		iconColor: '#10b981',
		title: 'Enseñanza & Blockchain Training'
	}
];
---

<section id="what-i-do">
	<div class="container">
		<h2 class="section-title">Diseño de soluciones escalables en la nube y Web3</h2>
		
		<div class="services-grid">
			{services.map((service) => (
				<div class="service-card card">
					<div class="service-icon" style={`background: ${service.iconColor}15; color: ${service.iconColor};`}>
						<i class={service.icon}></i>
					</div>
					<h3 class="service-title">{service.title}</h3>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	#what-i-do {
		background: var(--bg-dark);
	}

	.section-title {
		text-align: center;
		margin-bottom: 4rem;
		font-size: 2rem;
		color: var(--text-secondary);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.service-card {
		text-align: center;
		cursor: pointer;
	}

	.service-icon {
		width: 80px;
		height: 80px;
		margin: 0 auto 1.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 1rem;
		font-size: 2rem;
		transition: all 0.3s ease;
	}

	.service-card:hover .service-icon {
		transform: scale(1.1) rotate(-5deg);
	}

	.service-title {
		font-size: 1.1rem;
		font-weight: 500;
		color: var(--text-primary);
		line-height: 1.5;
	}

	@media (max-width: 768px) {
		.services-grid {
			grid-template-columns: 1fr;
		}

		.section-title {
			font-size: 1.5rem;
		}
	}
</style>
