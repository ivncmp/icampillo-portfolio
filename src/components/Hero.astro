---
import { BIO } from '../data/index';
import IDE from './ide/IDE';
---

<section id="top" class="hero">
  <!-- Photo background -->
  <div class="hero-photo" />
  <!-- Dark tint -->
  <div class="hero-tint" />
  <!-- Left vignette for text legibility -->
  <div class="hero-vignette" />
  <!-- Bottom fade to bg -->
  <div class="hero-bottom-fade" />
  <!-- Decorative lime glow -->
  <div class="hero-glow" />

  <div class="hero-content">

    <!-- Prompt line -->
    <div class="hero-prompt">
      <span class="hero-prompt-user">ivan</span>
      <span class="hero-prompt-host">@portfolio</span>
      <span class="hero-prompt-sep">:</span>
      <span class="hero-prompt-path">~</span>
      <span class="hero-prompt-dollar">$ </span>
      <span class="hero-prompt-cmd">cat whoami.md</span>
    </div>

    <!-- Display name -->
    <h1 class="hero-name">
      Iván <span class="hero-name-accent">Campillo</span>
    </h1>

    <!-- Typing roles -->
    <div class="hero-roles">
      <span class="hero-roles-prefix">&gt; role:</span>
      <span id="typing-text" class="hero-roles-value"></span>
      <span class="hero-cursor" />
    </div>

    <!-- CTAs -->
    <div class="hero-ctas">
      <a href="#contact" class="btn btn-primary">
        <span>▸</span> start a project
      </a>
      <a href="#work" class="btn btn-ghost">
        <span class="hero-cta-prefix">./</span>view work
      </a>
      <a href="#oss" class="btn btn-ghost">
        <span>⎇</span> github
      </a>
    </div>

    <div class="ide-section">
      <IDE client:load />
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 140px 32px 40px;
    overflow: hidden;
    min-height: 720px;
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    background-image: url('https://icampillo.com/wp-content/uploads/2025/06/hero-bg.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0.95;
  }

  .hero-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.25) 0%,
      rgba(10, 10, 10, 0.15) 40%,
      rgba(10, 10, 10, 0.75) 100%
    );
    pointer-events: none;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 55% 70% at 20% 50%,
      rgba(10, 10, 10, 0.75),
      transparent 70%
    );
    pointer-events: none;
  }

  .hero-bottom-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(180deg, transparent, var(--bg) 80%);
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    left: 50%;
    top: 120px;
    transform: translateX(-50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(200, 255, 0, 0.12), transparent 70%);
    pointer-events: none;
    filter: blur(40px);
    animation: float 6s ease-in-out infinite;
  }

  .hero-content {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(126, 231, 135, 0.08);
    border: 1px solid rgba(126, 231, 135, 0.25);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent-2);
    margin-bottom: 28px;
  }

  .hero-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--accent-2);
    box-shadow: 0 0 8px var(--accent-2);
    animation: pulse 2s ease-in-out infinite;
  }

  .hero-prompt {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg-dim);
    margin-bottom: 20px;
  }

  .hero-prompt-user { color: var(--accent-2); }
  .hero-prompt-host { color: var(--fg-mute); }
  .hero-prompt-sep { color: var(--fg-mute); }
  .hero-prompt-path { color: var(--cyan); }
  .hero-prompt-dollar { color: var(--fg-mute); }
  .hero-prompt-cmd { color: var(--fg); }

  .hero-name {
    font-family: var(--display);
    font-weight: 600;
    font-size: 126px;
    line-height: 0.92;
    letter-spacing: 0;
    color: var(--fg);
    white-space: nowrap;
  }

  .hero-name-accent {
    color: var(--accent);
  }

  .hero-roles {
    margin-top: 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 28px;
    font-weight: 500;
    color: var(--fg-dim);
  }

  .hero-roles-prefix {
    color: var(--fg-mute);
  }

  .hero-roles-value {
    color: var(--accent);
    display: inline-flex;
    align-items: center;
  }

  .hero-cursor {
    display: inline-block;
    width: 3px;
    height: 28px;
    background: var(--accent);
    vertical-align: text-bottom;
    margin-left: 4px;
    animation: blink 1s steps(2) infinite;
  }

  .hero-summary {
    margin-top: 28px;
    max-width: 640px;
    font-family: var(--sans);
    font-size: 20px;
    color: var(--fg-dim);
    line-height: 1.5;
    text-wrap: balance;
  }

  .hero-summary :global(.hero-summary-highlight) {
    color: var(--accent);
    font-weight: 600;
  }

  .hero-ctas {
    margin-top: 40px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-cta-prefix {
    color: var(--fg-mute);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 120px 20px 60px;
    }

    .hero-name {
      white-space: normal;
    }

    .hero-roles {
      font-size: 20px;
    }

    .hero-cursor {
      height: 20px;
    }
  }
</style>

<script define:vars={{ roles: BIO.roles.map(r => r.title) }}>
  const el = document.getElementById('typing-text');
  if (el) {
    let idx = 0;
    let text = '';
    let phase = 'typing';

    function tick() {
      const current = roles[idx];

      if (phase === 'typing') {
        if (text.length < current.length) {
          text = current.slice(0, text.length + 1);
          el.textContent = text;
          setTimeout(tick, 55);
        } else {
          phase = 'hold';
          setTimeout(tick, 1400);
        }
      } else if (phase === 'hold') {
        phase = 'deleting';
        setTimeout(tick, 1200);
      } else if (phase === 'deleting') {
        if (text.length > 0) {
          text = current.slice(0, text.length - 1);
          el.textContent = text;
          setTimeout(tick, 28);
        } else {
          idx = (idx + 1) % roles.length;
          phase = 'typing';
          setTimeout(tick, 200);
        }
      }
    }

    setTimeout(tick, 600);
  }
</script>
