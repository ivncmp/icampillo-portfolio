---
const projects = [
	{
		title: '5TARS',
		description: 'El juego definitivo de predicciones deportivas y fantasy web3 impulsado por IA',
		tech: 'AWS, NodeJS, Angular, SQL and NoSQL databases',
		link: 'https://5tars.io'
	},
	{
		title: 'My-Bowling',
		description: 'Plataforma de gestión multi-federación para clubs de bolos con IA',
		tech: 'React, TypeScript, Supabase, Deno Edge Functions',
		link: 'https://my-bowling.vercel.app'
	},
	{
		title: 'WavEconomy',
		description: 'SaaS B2B de evaluación empresarial con economía de tokens WAVE',
		tech: 'React, TypeScript, Material-UI, Supabase',
		link: 'https://waveconomy.vercel.app'
	},
	{
		title: 'CrayfishJS',
		description: 'Framework TypeScript ligero para AWS Lambda serverless',
		tech: 'TypeScript, Node.js, AWS Lambda, CLI',
		link: 'https://github.com/ivncmp/crayfish-js'
	},
	{
		title: 'Starzplay Cricket Contest',
		description: 'Aumentar la participación de los aficionados al cricket mediante la gamificación',
		tech: 'AWS, NodeJS, Angular, SQL and NoSQL databases',
		link: '#'
	}
];
---

<section id="projects">
	<div class="container">
		<h2 class="section-title">{ Web Dev Portfolio }</h2>
		<p class="section-subtitle">Galería de Proyectos</p>
		
		<div class="projects-grid">
			{projects.map((project) => (
				<div class="project-card">
					<div class="project-content">
						<h3 class="project-title">{project.title}</h3>
						<p class="project-description">{project.description}</p>
						<div class="project-tech">
							<span class="tech-label">Tecnologías:</span>
							<p>{project.tech}</p>
						</div>
					</div>
					{project.link !== '#' && (
						<a href={project.link} target="_blank" rel="noopener noreferrer" class="project-link">
							Ver proyecto <i class="fas fa-arrow-right"></i>
						</a>
					)}
				</div>
			))}
		</div>
	</div>
</section>

<style>
	#projects {
		background: white;
	}

	.section-title {
		text-align: center;
		margin-bottom: 1rem;
		color: var(--primary-color);
		font-size: 2.5rem;
	}

	.section-subtitle {
		text-align: center;
		color: var(--text-light);
		font-size: 1.2rem;
		margin-bottom: 4rem;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 2.5rem;
	}

	.project-card {
		background: var(--bg-gray);
		border-radius: 1rem;
		overflow: hidden;
		transition: all 0.3s ease;
		border: 2px solid transparent;
		display: flex;
		flex-direction: column;
	}

	.project-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 20px 50px rgba(0,0,0,0.15);
		border-color: var(--accent-color);
	}

	.project-content {
		padding: 2rem;
		flex: 1;
	}

	.project-title {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: var(--primary-color);
	}

	.project-description {
		color: var(--text-color);
		margin-bottom: 1.5rem;
		line-height: 1.6;
	}

	.project-tech {
		background: white;
		padding: 1rem;
		border-radius: 0.5rem;
		border-left: 4px solid var(--accent-color);
	}

	.tech-label {
		font-weight: 600;
		color: var(--text-color);
		display: block;
		margin-bottom: 0.5rem;
	}

	.project-tech p {
		color: var(--text-light);
		font-size: 0.9rem;
	}

	.project-link {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 1rem;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		font-weight: 600;
		transition: all 0.3s ease;
	}

	.project-link:hover {
		background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
	}

	.project-link i {
		transition: transform 0.3s ease;
	}

	.project-link:hover i {
		transform: translateX(5px);
	}

	@media (max-width: 768px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}

		.section-title {
			font-size: 2rem;
		}
	}
</style>
